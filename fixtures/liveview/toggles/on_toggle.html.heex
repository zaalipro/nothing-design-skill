<button
  class="flex items-center gap-sm min-h-[44px]"
  role="switch"
  aria-checked="true">
  <span class="font-mono text-label uppercase text-nd-text-secondary">AUTO-SYNC</span>
  <span class="relative w-12 h-6 rounded-full border transition-colors duration-nd-micro bg-nd-text-display border-nd-text-display">
    <span class="absolute top-0.5 left-0.5 w-5 h-5 rounded-full transition-transform duration-nd-micro translate-x-6 bg-nd-black dark:bg-nd-black"></span>
  </span>
</button>
